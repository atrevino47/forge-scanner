# ═══════════════════════════════════════════════════════
# FORGE FUNNEL SCANNER — Environment Variables
# Copy to .env.local and fill in real values
# ═══════════════════════════════════════════════════════

# ── REQUIRED: Core Infrastructure ─────────────────────

# Supabase — Database + Auth + Storage
# Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Application URL — MUST change for production
# Local: http://localhost:3000 | Production: https://audit.forgedigital.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── REQUIRED: AI & Capture ────────────────────────────

# Anthropic — AI analysis (Claude Sonnet + Haiku)
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Browserless — Headless browser for screenshot capture
# Get from: https://www.browserless.io → Dashboard → API Key
BROWSERLESS_API_KEY=

# ── REQUIRED: Booking ─────────────────────────────────

# Cal.com — Embedded scheduling
# Embed URL format: https://cal.com/your-username/strategy-call
# API key from: https://app.cal.com → Settings → Developer → API Keys
NEXT_PUBLIC_CALCOM_EMBED_URL=https://cal.com/your-username/strategy-call
CALCOM_API_KEY=cal_...

# Cal.com webhook secret — verify webhook authenticity
# Set when creating a webhook in Cal.com → Settings → Developer → Webhooks
CALCOM_WEBHOOK_SECRET=

# ── REQUIRED: Email ───────────────────────────────────

# Resend — Transactional email + drip sequences
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...

# ── RECOMMENDED: Analytics & SEO ──────────────────────

# PostHog — Product analytics
# Get from: https://posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google PageSpeed API — Core Web Vitals in landing analysis
# Get from: https://console.cloud.google.com → APIs → PageSpeed Insights API
GOOGLE_PAGESPEED_API_KEY=

# Google Places API — GBP detection + local business data
# Get from: https://console.cloud.google.com → APIs → Places API
GOOGLE_PLACES_API_KEY=

# ── RECOMMENDED: Social & Ad Enrichment ───────────────

# Facebook/Meta — Ad Library detection (traffic stage)
# Get from: https://developers.facebook.com → App → Settings → Basic
FACEBOOK_APP_ACCESS_TOKEN=

# Apify — Social profile scraping (follower counts, engagement)
# Get from: https://console.apify.com → Settings → Integrations → API Token
APIFY_API_TOKEN=

# ── OPTIONAL: Payments (team-initiated only) ──────────

# Stripe — Payment processing during strategy calls
# Get from: https://dashboard.stripe.com → Developers → API Keys
# Use test keys (sk_test_*) until production launch
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── OPTIONAL: Multi-channel Follow-up ─────────────────

# Twilio — SMS follow-up sequences
# Get from: https://console.twilio.com → Account → API Keys
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp Business — WhatsApp follow-up
# Get from: Meta Business Suite → WhatsApp → API Setup
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── ADMIN & SECURITY ─────────────────────────────────

# Admin access — comma-separated email addresses
# These emails get access to /admin/* routes
ADMIN_EMAILS=adrian@forgedigital.com

# Cron secret — protects /api/cron/* endpoints
# Generate: openssl rand -hex 32
CRON_SECRET=

# Sales knowledge — path to Hormozi playbook markdown
# Optional: enables AI Sales Agent with trained knowledge
SALES_KNOWLEDGE_PATH=
